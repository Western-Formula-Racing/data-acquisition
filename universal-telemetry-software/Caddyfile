{
	# Disable automatic HTTPS redirect on port 80 — we only serve on 9443
	auto_https off
	# Suppress the admin API (not needed on-device)
	admin off
}

# WSS/HTTPS endpoint — Pecan PWAs on HTTPS need wss:// not ws://
# Cert is auto-generated by Caddy's internal CA (no manual setup required).
# First-time: visit https://<rpi-ip>:9443 in browser and accept the cert warning,
# then wss://<rpi-ip>:9443 will work from any HTTPS PWA on the same network.
:9443 {
	tls internal

	reverse_proxy localhost:9080
}
