{
  "name": "pecan-live-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node production-server.js",
    "prod": "npm run build && npm run start",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:ci": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:tier1": "vitest run src/utils/canProcessor.test.ts src/lib/DataStore.test.ts src/utils/replayParser.test.ts",
    "test:tier2": "vitest run src/services/WebSocketService.test.ts src/services/TxWebSocketService.test.ts src/services/SerialService.test.ts",
    "test:tier3": "vitest run src/config/categories.test.ts src/lib/useDataStore.test.ts src/lib/usePageLock.test.ts src/lib/useRemoteConfig.test.ts"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.16",
    "@jitsi/react-sdk": "^1.4.4",
    "@tailwindcss/vite": "^4.1.13",
    "@types/plotly.js": "^3.0.8",
    "bootstrap": "^5.3.8",
    "candied": "^2.2.0",
    "dexie": "^4.3.0",
    "firebase": "^12.9.0",
    "lucide-react": "^0.562.0",
    "next-themes": "^0.4.6",
    "pako": "^2.1.0",
    "plotly.js-dist-min": "^3.3.0",
    "react": "^19.1.1",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.1.1",
    "react-router": "^7.9.3",
    "reactflow": "^11.11.4",
    "recharts": "^3.7.0",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^4.1.13",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.7.1",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.1.17",
    "@types/react-dom": "^19.1.9",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.3",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "firebase-tools": "^15.5.1",
    "globals": "^16.4.0",
    "jsdom": "^26.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.44.0",
    "vite": "^7.1.7",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.17"
  }
}
